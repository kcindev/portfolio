---
import Layout from "../layouts/Layout.astro";
import { Skull } from "@lucide/astro";

// Import the JSON data
import blogPosts from "../data/blog.json";
---

<Layout>
	<section id="header" class="md:h-[50vh] flex flex-col justify-end pl-4 pr-4 md:pr-0 pt-4 mb-10">
		<h1 class="text-2xl md:text-3xl mb-5">
			<span class="theme-text text-3xl font-bold">Nick Luca,</span><br/>
			Software developer, CS Student
		</h1>
		<p class="text-md mb-5">
			I'm a Computer Science student building hands-on experience in full-stack development, systems administration, automation, and IT infrastructure.
		</p>
		<div class="flex gap-2">
			<a href="/projects" class="text-sm px-3 py-2 rounded-lg btn transition-colors duration-200 hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-blue-400">
				See my projects
			</a>
			<a href="/contact" class="text-sm px-3 py-2 rounded-lg btn transition-colors duration-200 hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-blue-400">
				Contact Me
			</a>
			<a href="/Nick_Luca_Resume.pdf" class="text-sm px-3 py-2 rounded-lg btn transition-colors duration-200 hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-blue-400" target="_blank" rel="noopener noreferrer">
				Resume
			</a>
		</div>
	</section>
	<section id="body" class="pl-4 pr-4 md:pr-0">
		<h2 class="text-lg mb-6">Recent blog posts</h2>
		{blogPosts.map((post) => (
			<div class="post mb-6 md:flex gap-3">
				<div class="md:w-[10%]">
					<p class="text-sm">{post.date}</p>
				</div>
				<a href={`/p/${post.slug}`} class="md:w-[90%]">
					<h3 class="text-md mb-1">
						{post.title}
					</h3>
					<p class="text-sm muted line-clamp-3">
						{post.excerpt}
					</p>
				</a>
			</div>
		))}
	</section>
</Layout>