---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";

// ------------------
// Types
// ------------------
type Project = {
  title: string;
  description: string;
  images: string[];
  logo?: string;
  repo?: string;
  demo?: string;
  stack: string[];
  category?: string;
  year: number;
};

// ------------------
// Import JSON
// ------------------
import projectsRaw from "../data/projects.json";
const projects = (projectsRaw as Project[])
  .map((project) => ({
    ...project,
    images: project.images.filter((image) => image.trim().length > 0),
  }))
  .sort((a, b) => b.year - a.year);
---

<Layout>
  <section id="header" class="md:h-[50vh] flex flex-col justify-end pl-4 pr-4 md:pr-0 pt-4 mb-5">
        <h1 class="text-2xl md:text-3xl mb-5">
			Projects
		</h1>
        <h2 class="text-lg md:text-xl">These are some of the things I've worked on recently. Most of them are open-source on Github.</h2>
    </section>

  <section class="pl-4 pr-4 md:pr-0 max-w-4xl">
    {projects.map((project, index) => (
      <details
        class="group border-b theme-border py-5"
        open={index < 2}
      >
        <summary class="flex justify-between items-center cursor-pointer list-none">
          <span class="text-lg">{project.title}</span>
          <span class="muted text-sm">{project.year}</span>
        </summary>

        <div class="mt-4 space-y-4 text-md">

          {/* Images */}
          {project.images?.length > 0 && (
            <div class="flex gap-4 overflow-x-auto pb-2 hide-scrollbar">
              {project.images.map((img, imageIndex) => (
                <button
                  type="button"
                  class="group relative h-52 shrink-0 overflow-hidden border theme-border focus:outline-none"
                  data-lightbox-trigger
                  data-lightbox-src={img}
                  data-lightbox-alt={`${project.title} preview`}
                  aria-label={`Open ${project.title} preview`}
                >
                  <Image
                    src={img}
                    alt={project.title}
                    width={416}
                    height={208}
                    class="h-full w-auto object-cover transition-transform duration-300 hover:scale-105"
                    loading={index === 0 && imageIndex === 0 ? "eager" : "lazy"}
                  />
                  <span class="absolute inset-0 bg-black/0 transition-colors duration-300 group-hover:bg-black/10"></span>
                </button>
              ))}
            </div>
          )}

          
          <p class="muted">{project.description}</p>

          <div class="flex flex-wrap gap-2">
            {project.stack.map((tech) => (
              <span class="px-3 py-1 border theme-border text-sm">
                {tech}
              </span>
            ))}
          </div>

          {/* Links */}
          <div class="flex gap-6 text-sm">
            {project.repo && (
              <a
                href={project.repo}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Open ${project.title} repository`}
                class="muted hover:theme-text"
              >
                Repository
              </a>
            )}
            {project.demo && (
              <a
                href={project.demo}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Open ${project.title} live demo`}
                class="muted hover:theme-text"
              >
                Live Demo
              </a>
            )}
          </div>
        </div>
      </details>
    ))}
  </section>

  <div
    id="lightbox"
    class="fixed inset-0 z-[10000] hidden items-center justify-center bg-black/90 px-4 py-8"
    aria-hidden="true"
  >
    <button
      type="button"
      class="absolute inset-0 cursor-zoom-out"
      data-lightbox-close
      aria-label="Close image preview"
    ></button>
    <div class="relative z-10 max-h-full">
      <img
        id="lightbox-image"
        src=""
        alt=""
        class="w-full h-full max-h-[90vh] max-w-[95vw] border border-white/10 object-contain shadow-2xl"
      />
      <button
        type="button"
        class="absolute -right-2 -top-2 rounded-full bg-white/10 px-3 py-1 text-sm text-white backdrop-blur-sm transition-colors hover:bg-white/20"
        data-lightbox-close
      >
        Close
      </button>
    </div>
  </div>

  <script>
    const lightbox = document.getElementById('lightbox');
    const lightboxImage = document.getElementById('lightbox-image');
    const openTriggers = document.querySelectorAll('[data-lightbox-trigger]');
    const closeTriggers = document.querySelectorAll('[data-lightbox-close]');

    function openLightbox(src, alt) {
      if (!lightbox || !lightboxImage) return;
      lightboxImage.src = src;
      lightboxImage.alt = alt || 'Image preview';
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      if (!lightbox || !lightboxImage) return;
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      lightbox.setAttribute('aria-hidden', 'true');
      lightboxImage.src = '';
      lightboxImage.alt = '';
      document.body.style.overflow = '';
    }

    openTriggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        openLightbox(trigger.getAttribute('data-lightbox-src') || '', trigger.getAttribute('data-lightbox-alt') || 'Image preview');
      });
    });

    closeTriggers.forEach((trigger) => {
      trigger.addEventListener('click', closeLightbox);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeLightbox();
      }
    });
  </script>
</Layout>
