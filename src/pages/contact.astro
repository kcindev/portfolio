---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <!-- Header -->
  <section id="header" class="md:h-[50vh] flex flex-col justify-end pl-4 pr-4 md:pr-0 pt-4 mb-5">
        <h1 class="text-2xl md:text-3xl mb-5">
			Contact
		</h1>
        <h2 class="text-lg md:text-xl">Feel free to reach out to me for anything. Email me for serious inquiries. Discord works for everything else.</h2>
    </section>

  <!-- Contact info -->
  <section class="pl-4 pr-4 md:pr-0 mb-10 space-y-3 text-md">
    <p>
      <strong>Email:</strong> 
      <a href="mailto:luca.nickk@gmail.com" class="muted hover:theme-text">
        luca.nickk@gmail.com
      </a>
    </p>
    <p>
      <strong>Discord:</strong> 
      <a href="https://discord.com/users/195712965536776192" target="_blank" class="muted hover:theme-text">
        @kcindev
      </a>
    </p>
    <p>
      <strong>GitHub:</strong> 
      <a href="https://github.com/kcindev" target="_blank" class="muted hover:theme-text">
        @kcindev
      </a>
    </p>
    <p>
      <strong>LinkedIn:</strong> 
      <a href="https://linkedin.com/in/kcindev/" target="_blank" class="muted hover:theme-text">
        /in/kcindev
      </a>
    </p>
    <p>
      <strong>Instagram:</strong> 
      <a href="https://instagram.com/nicklluca_/" target="_blank" class="muted hover:theme-text">
        @nicklluca_
      </a>
    </p>
  </section>

  <!-- Contact form -->
  <section class="pl-4 pr-4 md:pr-0 max-w-3xl pb-10">
    <form class="flex flex-col gap-4" action="https://api.web3forms.com/submit" method="POST">
      <input type="hidden" name="access_key" value="4ef22e8d-e439-40c3-a60e-efaace963993" />
      <div class="flex flex-col">
        <label for="name" class="muted text-sm mb-1">Name</label>
        <input type="text" name="name" id="name" required class="px-3 py-2" />
      </div>

      <div class="flex flex-col">
        <label for="email" class="muted text-sm mb-1">Email</label>
        <input type="email" name="email" id="email" required class="px-3 py-2" />
      </div>

      <div class="flex flex-col">
        <label for="message" class="muted text-sm mb-1">Message</label>
        <textarea name="message" id="message" rows="5" required class="px-3 py-2 resize-none"></textarea>
      </div>

      <button type="submit" class="btn px-4 py-2 w-max">
        Send
      </button>
    </form>
    <script is:inline>
      document.getElementById('contact-form').onsubmit = async function(e) {
        e.preventDefault();
        const form = e.target;
        const submitBtn = document.getElementById('contact-submit');
        const status = document.getElementById('contact-status');
        submitBtn.disabled = true;
        status.textContent = '';
        const data = {
          name: form.name.value,
          email: form.email.value,
          message: form.message.value
        };
        try {
          const res = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });
          const result = await res.json();
          if (result.success) {
            status.textContent = 'Message sent!';
            form.reset();
          } else {
            status.textContent = 'Failed to send: ' + (result.error || 'Unknown error');
          }
        } catch (err) {
          status.textContent = 'Failed to send: ' + err.message;
        }
        submitBtn.disabled = false;
      }
    </script>
  </section>
</Layout>
