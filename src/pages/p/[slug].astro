---
import '../../styles/markdown.css';
import Layout from "../../layouts/Layout.astro";
import blogPosts from "../../data/blog.json";
import { marked } from 'marked';
import fs from 'fs';
import path from 'path';

function escapeHtml(value: string) {
  return value
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function renderSketchNote(text: string) {
  return `<span class="sketch-note" aria-label="Handwritten annotation"><span class="sketch-note__arrow" aria-hidden="true"></span><span class="sketch-note__text">${escapeHtml(text.trim() || text)}</span></span>`;
}

function renderAnnotatedText(text: string) {
  const annotationPattern = /\{([^{}]+)\}/g;
  let output = '';
  let lastIndex = 0;
  let match: RegExpExecArray | null;

  while ((match = annotationPattern.exec(text)) !== null) {
    output += escapeHtml(text.slice(lastIndex, match.index));
    output += renderSketchNote(match[1]);
    lastIndex = match.index + match[0].length;
  }

  output += escapeHtml(text.slice(lastIndex));
  return output;
}

marked.use({
  renderer: {
    text(token) {
      return renderAnnotatedText(token.text);
    },
  },
});

export async function getStaticPaths() {
  return blogPosts.map(post => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const postMeta = blogPosts.find(p => p.slug === slug);

if (!postMeta) {
  return Astro.redirect("/404");
}

// Read markdown file
let renderedContent = "";
try {
  const filePath = path.join(process.cwd(), 'public', 'p', `${slug}.md`);
  const postContent = fs.readFileSync(filePath, 'utf-8');
  const parsed = marked.parse(postContent);
  if (typeof parsed === 'string') {
    renderedContent = parsed;
  } else if (parsed instanceof Promise) {
    renderedContent = await parsed;
  } else {
    renderedContent = String(parsed);
  }
} catch (err) {
  console.error(err);
  renderedContent = "<p>Failed to load post content.</p>";
}

// Prepare SEO props
const seoTitle = `${postMeta.title} | Nick Luca`;
const seoDescription = postMeta.excerpt || postMeta.excerpt || "Read this blog post by Nick Luca.";
const seoUrl = `https://kcin.dev/p/${slug}`;
const seoImage = postMeta.image || '/default-og-image.png';
const tags = postMeta.tags?.join(', ');
---

<Layout title={seoTitle} description={seoDescription} url={seoUrl} image={seoImage}>
  <!-- Header -->
  <section id="header" class="md:h-[50vh] flex flex-col justify-end pl-4 pr-4 md:pr-0 pt-4 mb-5">
    <a href="/" class="text-sm text-blue-500 hover:text-blue-600 mb-2 inline-block">
      ← Back to home
    </a>
    <h1 class="text-2xl md:text-3xl my-2">{postMeta.title}</h1>
    <div class="flex items-center gap-3 text-sm muted">
      <span>{postMeta.date}</span>
      <span>•</span>
      <span>{postMeta.readTime}</span>
    </div>
  </section>

  <!-- Body -->
  <section id="body" class="pl-4 pr-4 md:pr-0 md:pb-6">
    <main class="min-h-screen md:pt-5">
      <article class="prose prose-invert max-w-none blog-content">
        <div set:html={renderedContent} />
      </article>
    </main>
  </section>

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": "{postMeta.title}",
      "author": { "@type": "Person", "name": "Nick Luca" },
      "datePublished": "{postMeta.date}",
      "url": "{seoUrl}",
      "image": "{seoImage}",
      "description": "{seoDescription}",
      "keywords": "{tags}"
    }
  </script>

  <!-- Highlight.js -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/nord.min.css">
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
  <script is:inline>
    hljs.highlightAll();
  </script>

  <style is:global>
    pre {
      background: var(--surface) !important;
      border-radius: 0.75rem;
      border: 1px solid var(--border);
      padding: 1.5rem !important;
      margin: 1.5rem 0;
      max-height: 400px;
      overflow-y: auto;
      overflow-x: auto;
      color: var(--text);
    }
    pre code {
      background: transparent !important;
      padding: 0 !important;
      border-radius: 0;
      border: none;
    }
    :not(pre) > code {
      background: color-mix(in srgb, var(--text) 6%, transparent 94%);
      padding: 0.2rem 0.4rem;
      border-radius: 0.375rem;
      border: 1px solid var(--border);
      font-size: 0.875em;
      color: var(--text);
    }
  </style>
</Layout>
